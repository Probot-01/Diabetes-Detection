# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Model and scaler files (too large for git — host on Google Drive)
*.pkl
*.joblib

# Raw numpy data arrays
*.npy
*.npz

# Datasets — exclude all CSV except the results summary
*.csv
!evaluation/final_results.csv

# Keep the models folder placeholder
!models/.gitkeep

# Audio files (auto-generated or user recordings)
*.wav
*.mp3
*.ogg
*.webm
temp_audio/

# Virtual environments
venv/
env/
.env

# Jupyter/Colab cache
.ipynb_checkpoints/

# OS generated files
.DS_Store
Thumbs.db
